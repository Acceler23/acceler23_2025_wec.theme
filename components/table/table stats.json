{
    "ComponentName": "session_stats_cell",
    "BlockType": "stack",
    "Background": "{DarkBlue}",
    "Height": "{TableLineHeight}",
    "Width": "*",
    "Padding": "10, 0",
    "Triggers": [
        {
            "Trigger": "LeaderColorTeam"
        },
        {
            "Trigger": "LeaderColorCar"
        }
    ],
    "Items": [
        {
            "BlockType": "text",
            "Source": "[<{data.Value}>]",
            "PaddingLeft": 20,
            "PaddingRight": 20,
            "Background": "{DarkBlue}",
            "Style": "Session_Style",
            "FontName": "{FontTiming}",
            "HorizontalAlignment": "Right",
            "Triggers": [
                {
                    "Trigger": "LeaderColorTeam"
                },
                {
                    "Trigger": "LeaderColorCar"
                }
            ]
        },
        //stint
        {
            "BlockType": "itemstack",
            "PaddingLeft": 20,
            "PaddingRight": 20,
            "Background": "{DarkBlue}",
            "Width": "*",
            "Style": "Session_Style",
            "Triggers": [
                {
                    "Trigger": "LeaderColorTeam"
                },
                {
                    "Trigger": "LeaderColorCar"
                }
            ],
            "ItemStackOptions": {
                "ItemSource": "<{data.Stints}>",
                "ItemTemplate": {
                    "BlockType": "stack",
                    "Height": "{TableLineHeight}",
                    "VerticalAlignment": "Center",
                    "Orientation": "Horizontal",
                    "Items": [
                        {
                            "BlockType": "image",
                            "Source": "tyres/tyres_{Item.Tyres}.png",
                            "Height": 20,
                            "MaxHeight": 72,
                            "Style": "Session_Style",
                            "Padding": "10,0,0,0"
                        },
                        {
                            "BlockType": "text",
                            "Style": "Session_Style",
                            "Foreground": "#ffffff",
                            "Source": "{Item.Laps}",
                            "FontName": "{FontTiming}",
                            "Padding": "5, 0, 0, 0",
                            "Triggers": [
                                {
                                    "Condition": "{Item.IsPercentage}",
                                    "Setters": [
                                        {
                                            "Property": "Source",
                                            "Value": "{Item.Percentage, Converter=StringAdd, Parameter=%}"
                                        }
                                    ]
                                },
                                {
                                    "Condition": "{Item.Tyres, Converter=StringEquals, Parameter=Hard}",
                                    "Property": "Foreground",
                                    "Value": "#FF0000"
                                },
                                {
                                    "Condition": "{Item.Tyres, Converter=StringEquals, Parameter=Medium}",
                                    "Property": "Foreground",
                                    "Value": "#949400"
                                },
                                {
                                    "Condition": "{Item.Tyres, Converter=StringEquals, Parameter=Soft}",
                                    "Property": "Foreground",
                                    "Value": "#FF8B8B8B"
                                },
                                {
                                    "Condition": "{Item.Tyres, Converter=StringEquals, Parameter=Wet}",
                                    "Property": "Foreground",
                                    "Value": "#0059FF"
                                }
                            ]
                        }
                    ]
                }
            }
        }
    ]
}