{
    "ComponentName": "fastest_lap",
    "BlockType": "itemstack",
    "Orientation": "Horizontal",
    "Height": "{TableLineHeight}",
    "Background": "{Purple}",
    "Width": "{TableWidth}",
    "ItemStackOptions": {
        "ItemSource": "{Session.Drivers}",
        "FilterMember": "IsRaceFastestLap",
        "FilterMemberValue": "True",
        "ItemTemplate": {
            "BlockType": "stack",
            "Orientation": "Horizontal",
            "Items": [
                {
                    "BlockType": "dock",
                    "Width": 57,
                    "Height": "{TableLineHeight}",
                    "Items": [
                        {
                            "BlockType": "image",
                            "Source": "clock",
                            "Foreground": "{White}",
                            "HorizontalAlignment": "Center",
                            "VerticalAlignment": "Center",
                            "Height": 30,
                            "Colorize": {
                                "Color": "{White}"
                            }
                        }
                    ]
                },
                {
                    "BlockType": "text",
                    "Source": "{Item.FastestLapTime}",
                    "Style": "FL_Stile",
                    "Width": 137,
                    "HorizontalAlignment": "Right"
                },
                {
                    "BlockType": "text",
                    "Source": "[{Item.Driver.{NameConvention}, Converter=StringToUpperString}]",
                    "Style": "FL_Stile",
                    "MarginLeft": 27,
                    "Width": 360
                },
                {
                    "BlockType": "stack",
                    "Height": "{TableLineHeight}",
                    "Width": 474,
                    "Items": [
                        {
                            "BlockType": "text",
                            "Source": "{Item.{CarNumber}, Converter=StringToUpperString}",
                            "Style": "FL_Stile",
                            "FontName": "{FontTableRegular}",

                        },
                        {
                            "BlockType": "text",
                            "Source": " | [{Item.Team.FullName, Converter=StringToUpperString}]",
                            "Style": "FL_Stile",
                            "FontName": "{FontTableRegular}",
                            "Triggers": [
                                {
                                    "Condition": "{Season.LineupsBasedType, Converter=StringEquals, Parameter=Cars}",
                                    "Property": "Source",
                                    "Value": " | {Item.Car.Name, Converter=StringToUpperString}"
                                }
                            ]
                        }
                    ]
                },
                {
                    "BlockType": "text",
                    "RenderIf": "{Item.FastestLapNumLap, Converter=NumberGreater, Parameter=0}",
                    "Source": "[LAP] {Item.FastestLapNumLap}",
                    "Style": "FL_Stile",
                    "Width": 150
                }
            ]
        }
    }
}