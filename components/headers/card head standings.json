{
    "ComponentName": "card_head_standings",
    "BlockType": "canvas",
    "Orientation": "Vertical",
    //"Margin": "50",
    "Items": [
        {
            "BlockType": "image",
            "Source": "Session/racename_bg.png",
            "Width": 240,
            "PositionX": 0,
            "PositionY": 38,
            "Colorize": {
                "Color": "{LightBlue}",
                "ColorBlendingMode": "Normal"
            }
        },
        {
            "BlockType": "dock",
            "Height": 50,
            "Width": 90,
            "PositionX": 0,
            "PositionY": 0,
            //"Background": "#dddddd",
            "Items": [
                {
                    "BlockType": "image",
                    "Height": 50,
                    "Source": "{Season.LogotypePath}",
                    "VerticalAlignment": "Bottom",
                    "HorizontalAlignment": "Right"
                }
            ]
        },
        {
            "BlockType": "stack",
            "Orientation": "Vertical",
            "PositionY": 20,
            "PositionX": 93,
            "Items": [
                {
                    "BlockType": "stack",
                    "Orientation": "Horizontal",
                    "Items": [
                        {
                            "BlockType": "text",
                            "Source": "[{Season.LeagueInfo.LeagueName, Converter=StringToUpperString}]",
                            "FontName": "{FontLeagueCard}",
                            "Foreground": "{White}",
                            "FontSize": 11
                        },
                        {
                            "BlockType": "text",
                            "Source": " [{Season.Name, Converter=StringToUpperString}]",
                            "FontName": "{FontLeagueCard}",
                            "Foreground": "{LightBlue}",
                            "FontSize": 11
                        }
                    ]
                },
                {
                    "BlockType": "text",
                    "Source": "CHAMPIONSHIP",
                    "FontName": "{FontLeagueCard}",
                    "Foreground": "{White}",
                    "FontSize": 11
                }
            ]
        },
        {
            "BlockType": "text",
            "Source": "[{Standings.LastEvent.Track.CircuitFullName, Converter=StringToUpperString}]",
            "FontName": "{FontTrackName}",
            "FontSize": "{CardFontSize}",
            "Padding": "10",
            "HorizontalAlignment": "Left",
            "VerticalAlignment": "Center",
            "Width": "{CardMaxWidth}",
            "Height": 62,
            "PositionY": 45,
            "PositionX": -10,
            "MarginTop": 5,
            "Triggers": [
                {
                    "Trigger": "NameDescription2"
                }
            ],
            "TextOptions": {
                "Wrap": true,
                "TextAlignment": "Start",
                "VerticalAlignment": "Center"
            }
        },
        {
            "BlockType": "text",
            "Source": "{Standings.LastEvent.DateLocal, Converter=DateCustomFormat, Parameter=yyyy}",
            "FontName": "{FontYear}",
            "Foreground": "{White}",
            "FontSize": 17,
            "Padding": "5",
            "PositionY": 130,
            "PositionX": 5
        }
    ]
}